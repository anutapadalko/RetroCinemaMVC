@model IEnumerable<RetroCinemaDomain.Model.User>
<h2>Список користувачів</h2>
<table class="table">
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.Email</td>
            <td>
                <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-userid="@user.Id">Права доступу</a>
                <a class="btn btn-sm btn-warning" asp-controller="Account" asp-action="ChangePassword" asp-route-id="@user.Id">
                    Змінити пароль
                </a>
            </td>
        </tr>
    }
</table>